# =============================================================================
# microshort — environment variables
# =============================================================================
# Copy this file to .env and fill in the values before running the stack.
#
#   cp .env.example .env
#
# The placeholder values work for LOCAL DEVELOPMENT ONLY. Services refuse to
# start with `change-me` placeholder secrets when NODE_ENV=production.
#
# PRODUCTION NOTE: Never commit .env. Use your deployment platform's secret
# injection mechanism:
#   Docker Swarm : docker secret create / secrets: in compose file
#   Kubernetes   : kubectl create secret generic / envFrom: secretRef:
#   Ansible      : ansible-vault encrypt / vars injection via playbook
#   Terraform    : sensitive variable + remote state backend
#
# NOTE: changing a database password after first boot does NOT update the
# database (init scripts only run on an empty volume). After changing
# AUTH_DB_PASSWORD / URL_DB_PASSWORD / CLICKHOUSE_PASSWORD run:
#   docker compose down -v && docker compose up -d --build
# =============================================================================

# ----- Shared domain --------------------------------------------------------
# The public-facing base URL for all short links.
# Set to your public domain in production (e.g. https://sho.rt).
DOMAIN=http://localhost:8080

# ----- Auth service ---------------------------------------------------------
JWT_SECRET=change-me-in-production
AUTH_DB_PASSWORD=change-me-in-production

# ----- URL service ----------------------------------------------------------
URL_DB_PASSWORD=change-me-in-production
URL_DB_ROOT_PASSWORD=change-me-in-production

# ----- Per-service tokens (required) ----------------------------------------
# Each internal caller authenticates with its own token so a leaked token can
# be rotated without redeploying every service.
# Token used by redirect-service (→ analytics-service, url-service lookups)
REDIRECT_SERVICE_TOKEN=change-me-in-production-redirect
# Token used by url-service to call analytics-service
URL_SERVICE_TOKEN=change-me-in-production-url
# Token used by admin-service to call internal service stats APIs
ADMIN_SERVICE_TOKEN=change-me-in-production-admin

# ----- Legacy shared token (optional) ---------------------------------------
# Deprecated single shared token, still accepted by analytics-service when set
# so older callers keep working during a rotation. Leave unset for new setups.
# SERVICE_TOKEN=change-me-in-production

# ----- Redirect service -----------------------------------------------------
# Salt for SHA-256(client_ip + salt) before storing ip_hash in ClickHouse.
# Changing this invalidates all existing ip_hash values.
IP_HASH_SALT=change-me-in-production
# Rate limit for GET /:slug (per client IP). Defaults: 300 requests / 60s.
# Raise REDIRECT_RATE_LIMIT_MAX when load testing from a single source IP.
# REDIRECT_RATE_LIMIT_WINDOW_MS=60000
# REDIRECT_RATE_LIMIT_MAX=300

# ----- Config service -------------------------------------------------------
# Token required to write (PUT) the domain via config-service or admin-service.
CONFIG_WRITE_TOKEN=change-me-in-production

# ----- ClickHouse -----------------------------------------------------------
CLICKHOUSE_PASSWORD=change-me-in-production

# ----- Admin UI -------------------------------------------------------------
# Public (browser-reachable) URL for the admin service.
# In local dev this is always http://localhost:3003.
# In production, set to your admin-service public URL (https://...).
ADMIN_API_URL=http://localhost:3003

# ----- CORS -----------------------------------------------------------------
# Comma-separated list of allowed CORS origins for auth/url/admin services.
# Default: * (any origin). In any deployment where the admin UI is served
# over a real domain, restrict this to that origin, e.g.:
# ALLOWED_ORIGINS=https://admin.sho.rt

# ----- Reverse proxy --------------------------------------------------------
# Express `trust proxy` setting for services that rate-limit by client IP.
# 1 (default) = trust exactly one proxy hop (ALB / nginx / Caddy in front).
# 0 or false  = service is directly exposed (do not trust X-Forwarded-For).
# 2           = two hops (e.g. CloudFront → ALB).
# TRUST_PROXY=1
